# Supabase (optional — cloud sync / Google sign-in)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Get keys at https://console.mistral.ai — OCR is ~$1 per 1000 pages
VITE_MISTRAL_API_KEY=your_mistral_api_key_here
# AI chat (Deep Learn, SAQ, patient case, vignettes) — use one of:
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# VITE_GOOGLE_API_KEY=your_google_api_key_here

# Server-side (Supabase Edge Function secret, NOT a Vite var):
#   GEMINI_API_KEY — used by the generate-recognition-items Edge Function to
#   mold Anki cards into stored vignettes. Set it in the Supabase dashboard
#   → Edge Functions → Secrets (never expose it in the browser .env).
